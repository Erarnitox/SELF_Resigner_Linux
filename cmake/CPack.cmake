set(CPACK_PACKAGE_NAME "ps3_tools")
set(CPACK_PACKAGE_VENDOR "Erarnitox")
set(CPACK_PACKAGE_DESCRIPTION_SUMMARY "PS3 SELF resigner and EBOOT patcher tools")
if(NOT CPACK_PACKAGE_VERSION)
    set(CPACK_PACKAGE_VERSION "${PROJECT_VERSION}")
endif()
set(CPACK_COMPONENTS_ALL ps3_tools)
set(CPACK_COMPONENTS_GROUPING IGNORE)
set(CPACK_GENERATOR "ZIP")
set(CPACK_INCLUDE_TOPLEVEL_DIRECTORY OFF)

if(NOT CPACK_PACKAGE_VERSION OR CPACK_PACKAGE_VERSION STREQUAL "0.0.0")
    if(DEFINED ENV{CPACK_PACKAGE_VERSION} AND NOT "$ENV{CPACK_PACKAGE_VERSION}" STREQUAL "")
        set(CPACK_PACKAGE_VERSION "$ENV{CPACK_PACKAGE_VERSION}")
    endif()
endif()

if(CMAKE_SYSTEM_PROCESSOR MATCHES "^(AMD64|amd64|x86_64)$")
    set(_ps3_tools_arch "x86_64")
else()
    set(_ps3_tools_arch "${CMAKE_SYSTEM_PROCESSOR}")
endif()

if(CMAKE_SYSTEM_NAME STREQUAL "Linux")
    set(CPACK_SYSTEM_NAME "linux-${_ps3_tools_arch}")
elseif(CMAKE_SYSTEM_NAME STREQUAL "Windows")
    set(CPACK_SYSTEM_NAME "windows-${_ps3_tools_arch}")
else()
    set(CPACK_SYSTEM_NAME "${CMAKE_SYSTEM_NAME}-${_ps3_tools_arch}")
endif()

set(CPACK_PACKAGE_FILE_NAME "${CPACK_PACKAGE_NAME}-${CPACK_PACKAGE_VERSION}-${CPACK_SYSTEM_NAME}")

include(CPack)
